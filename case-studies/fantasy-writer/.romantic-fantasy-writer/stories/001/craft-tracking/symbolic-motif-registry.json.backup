  "motifs": [
    {
      "id": "MOT-001",
      "symbol": "The Pallor as flayed divine skin / membrane between order and chaos",
      "linkedTheme": "TP-1: Trust as structural failure — The Pallor is protection born from violence, a boundary that holds only through sustained damage. Like trust between enemies, it functions not through absence of threat but through containing it.",
      "appearances": [
        {
          "chapter": 1,
          "scene": "SCN-001",
          "imagery": "Silver membrane tears, reveals true starlight, knits closed like water finding level",
          "function": "Establishes Pallor as protective barrier beginning to fail"
        }
      ],
      "targetDensity": "3-4 appearances per act, evolving from protective barrier (Act I) to failing membrane (Act II) to wound reopened (Act III). Imagery should emphasize: silver thinning, tears revealing raw starlight, the skin metaphor becoming more explicit as crisis escalates."
    },
    {
      "id": "MOT-002",
      "symbol": "The Oathbrand as wound that will not heal / externalized guilt",
      "linkedTheme": "TP-2: The price of the right choice — The brand should have dissolved but keeps burning fresh because someone profits from the bleeding. Kaelith's self-punishment made literal and maintained by institutional violence.",
      "appearances": [
        {
          "chapter": 1,
          "scene": "SCN-001",
          "imagery": "Brand flares unexpectedly, heat spreading in waves, chronic burn that should have dissolved",
          "function": "Establishes Oathbrand as wound maintained by external force"
        },
        {
          "chapter": 2,
          "scene": "SCN-006",
          "imagery": "Oathbrand responding to Pallor tear — wound that shouldn't react to environmental disturbance but does, inflammation visible at collarbone",
          "function": "Deepens Oathbrand mystery — brand is not just suppression but connection to ontological layer"
        },
        {
          "chapter": 3,
          "scene": "SCN-007",
          "imagery": "Brand flares during message discovery, described as persistent burn that should have dissolved years ago. Heat spreading from collarbone in waves. Maintenance schedule revealed — the wound kept fresh deliberately.",
