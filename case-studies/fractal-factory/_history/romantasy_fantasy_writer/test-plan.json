      },
      "expectedBehavior": [
        "Orchestrator dispatches romantic-fantasy-writer-polish-coordinator",
        "Polish-coordinator dispatches romantic-fantasy-writer-polisher for chapter 1",
        "Polisher returns blocked (simulated failure)",
        "Polish-coordinator reads polisher blocked then writes own status: blocked",
        "Orchestrator reads polish-coordinator blocked then writes own status: delivered-with-gaps; summary: 'Polish incomplete'",
        "Orchestrator does NOT dispatch series-kb-manager (polish blocked short-circuits)"
      ],
      "expectedOutput": {
        "resultCode": "delivered-with-gaps",
        "artifactsWritten": [
          "agents/polish-coordinator/status.json (blocked)",
          "agents/polisher/status.json (blocked)",
